{
  "name": "data-charts",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "node --watch index.ts",
    "start": "node index.ts",
    "generate-test-charts": "node scripts/generate-test-charts.ts",
    "test": "node --test './**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "dependencies": {
    "chart.js": "4.5.1",
    "chartjs-chart-matrix": "3.0.4",
    "chartjs-chart-treemap": "3.1.0",
    "chartjs-plugin-datalabels": "2.2.0",
    "skia-canvas": "3.0.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^24.13.2",
    "eslint-plugin-sonarjs": "^4.1.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "oxlint-tsgolint": "^0.24.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.9.0"
}
